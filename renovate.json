{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":pinDevDependencies",
    ":maintainLockFilesWeekly"
  ],
  "configMigration": true,
  "automerge": true,
  "automergeType": "pr",
  "autoApprove": true,
  "prConcurrentLimit": 1,
  "prHourlyLimit": 0,
  "separateMinorPatch": false,
  "separateMultipleMajor": false,
  "packageRules": [
    {
      "matchDatasources": ["github-actions"],
      "matchUpdateTypes": ["major", "security", "pin"],
      "groupName": "GitHub Actions major updates",
      "groupSlug": "github-actions-major-updates",
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDatasources": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "enabled": false
    },
    {
      "matchDatasources": ["pypi"],
      "matchUpdateTypes": ["security", "pin"],
      "groupName": "pypi security updates",
      "groupSlug": "pypi-security-updates"
    },
    {
      "matchDatasources": ["pypi"],
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "enabled": false
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["security", "pin"],
      "groupName": "docker security updates",
      "groupSlug": "docker-security-updates"
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true
}
